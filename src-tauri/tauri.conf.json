{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "急急如律令",
  "version": "0.1.0",
  "identifier": "com.damon.jijirululing",
  "build": {
    "beforeDevCommand": "npm run dev:tauri-frontend",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "急急如律令",
        "width": 390,
        "height": 620,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
