{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "急急如律令",
  "version": "0.2.0",
  "identifier": "com.damon.jijirululing",
  "build": {
    "beforeDevCommand": "npm run dev:tauri-frontend",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "急急如律令",
        "width": 960,
        "height": 760,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "backgroundColor": "#00000000",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/app-icon/app-icon-v1@2x.png"]
  }
}
